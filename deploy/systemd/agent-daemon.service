[Unit]
Description=Leo Agent Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/leoprojects/agent-cli-v4-fresh
EnvironmentFile=/opt/leoprojects/agent-cli-v4-fresh/.env
ExecStart=/opt/leoprojects/agent-cli-v4-fresh/.venv/bin/python agent_daemon.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
